{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",

  // oh-my-opencode configuration
  // Model matching guide: https://github.com/code-yeongyu/oh-my-opencode/blob/dev/docs/guide/agent-model-matching.md
  //
  // New features in oh-my-opencode 3.x
  "new_task_system_enabled": false,
  "model_fallback": true,
  "hashline_edit": true,

  "agents": {
    "build": {
      "model": "f5ai-anthropic/claude-opus-4-6",
      "fallback_models": [
        "f5ai-anthropic/claude-opus-4-5",
        "f5ai-anthropic/claude-sonnet-4-6",
        "f5ai-anthropic/claude-sonnet-4-5"
      ]
    },
    "plan": {
      "model": "f5ai-anthropic/claude-opus-4-6",
      "fallback_models": [
        "f5ai-anthropic/claude-opus-4-5",
        "f5ai-anthropic/claude-sonnet-4-6",
        "f5ai-anthropic/claude-sonnet-4-5"
      ]
    },
    "sisyphus": {
      "model": "f5ai-anthropic/claude-opus-4-6",
      // Guide: Claude Opus → Claude family → GPT-5.4 (only GPT with dedicated Sisyphus prompt)
      "fallback_models": [
        "f5ai-anthropic/claude-opus-4-5",
        "f5ai-anthropic/claude-sonnet-4-6",
        "github-copilot/gpt-5.4",
        "f5ai-anthropic/claude-sonnet-4-5"
      ],
      // Deployment query routing (xc-planner for prod/staging questions)
      "prompt_append": "CRITICAL: For deployment questions (what's in prod/staging/crt/dev, deployed images, sre-*-model), delegate to @xc-planner. Local CI configs show :latest tags, not actual deployed versions."
    },
    "sisyphus-junior": {
      // Guide: Claude Sonnet → GPT-5.4
      "model": "f5ai-anthropic/claude-sonnet-4-6",
      "fallback_models": [
        "f5ai-anthropic/claude-sonnet-4-5",
        "github-copilot/gpt-5.4",
        "f5ai-anthropic/claude-haiku-4-5"
      ]
    },
    "prometheus": {
      // Guide: Claude Opus → GPT-5.4 → Gemini 3.1 Pro
      "model": "f5ai-anthropic/claude-opus-4-6",
      "fallback_models": [
        "f5ai-anthropic/claude-opus-4-5",
        "github-copilot/gpt-5.4",
        "github-copilot/gpt-5.3-codex",
        "github-copilot/gemini-3-pro-preview",
        "f5ai-anthropic/claude-sonnet-4-6"
      ],
      // Deployment query routing (xc-planner for prod/staging questions)
      "prompt_append": "CRITICAL: For deployment questions (what's in prod/staging/crt/dev, deployed images, sre-*-model), delegate to @xc-planner. Local CI configs show :latest tags, not actual deployed versions."
    },
    "metis": {
      // Guide: Claude Opus → GPT-5.4
      "model": "f5ai-anthropic/claude-opus-4-6",
      "fallback_models": [
        "f5ai-anthropic/claude-opus-4-5",
        "github-copilot/gpt-5.4",
        "github-copilot/gpt-5.3-codex",
        "github-copilot/gemini-3-pro-preview",
        "f5ai-anthropic/claude-sonnet-4-6"
      ]
    },
    "momus": {
      // Guide: GPT-5.4 → Claude Opus → Gemini 3.1 Pro (uses xhigh reasoning)
      "model": "github-copilot/gpt-5.4",
      "fallback_models": [
        "github-copilot/gpt-5.3-codex",
        "f5ai-anthropic/claude-opus-4-6",
        "github-copilot/gemini-3-pro-preview",
        "f5ai-anthropic/claude-sonnet-4-6"
      ],
      "reasoningEffort": "high"
    },
    "oracle": {
      // Guide: GPT-5.4 → Gemini 3.1 Pro → Claude Opus
      "model": "github-copilot/gpt-5.4",
      "fallback_models": [
        "github-copilot/gpt-5.3-codex",
        "github-copilot/gemini-3-pro-preview",
        "f5ai-anthropic/claude-opus-4-6",
        "f5ai-anthropic/claude-sonnet-4-6"
      ],
      // Extended thinking for architecture decisions
      "thinking": {
        "type": "enabled",
        "budgetTokens": 12000
      }
    },
    "librarian": {
      // Guide: Haiku → GPT-5-Nano (speed over intelligence)
      "model": "github-copilot/gemini-3-flash-preview",
      "fallback_models": [
        "f5ai-anthropic/claude-haiku-4-5",
        "github-copilot/gpt-5-mini",
        "f5ai-openai/gpt-5-nano"
      ]
    },
    "explore": {
      // Guide: Grok Code Fast → Haiku → GPT-5-Nano (speed is everything)
      "model": "f5ai-grok/grok-code-fast-1",
      "fallback_models": [
        "github-copilot/grok-code-fast-1",
        "f5ai-anthropic/claude-haiku-4-5",
        "github-copilot/gpt-5-mini",
        "f5ai-openai/gpt-5-nano"
      ]
    },
    "multimodal-looker": {
      // Guide: GPT-5.4 → GPT-5-Nano (multimodal-capable fallbacks)
      "model": "github-copilot/gpt-5.4",
      "fallback_models": [
        "github-copilot/gpt-5.3-codex",
        "github-copilot/gpt-5",
        "github-copilot/gpt-5-mini",
        "github-copilot/gemini-3-pro-preview",
        "f5ai-anthropic/claude-sonnet-4-6"
      ]
    },
    "hephaestus": {
      // Guide: GPT-5.3 Codex → GPT-5.4 (requires GPT — Claude is personality mismatch)
      // Autonomous Deep Worker — goal-oriented execution with thorough research
      "model": "f5ai-openai/gpt-5.3-codex",
      "fallback_models": [
        "github-copilot/gpt-5.3-codex",
        "github-copilot/gpt-5.4",
        "github-copilot/gpt-5.2-codex",
        "f5ai-anthropic/claude-opus-4-6"
      ],
      "reasoningEffort": "xhigh",
      // Deployment query routing (xc-planner for prod/staging questions)
      "prompt_append": "CRITICAL: For deployment questions (what's in prod/staging/crt/dev, deployed images, sre-*-model), delegate to @xc-planner. Local CI configs show :latest tags, not actual deployed versions."
    },
    "atlas": {
      // Guide: Claude Sonnet → GPT-5.4
      "model": "f5ai-anthropic/claude-sonnet-4-6",
      "fallback_models": [
        "f5ai-anthropic/claude-sonnet-4-5",
        "github-copilot/gpt-5.4",
        "f5ai-anthropic/claude-haiku-4-5"
      ]
    }
  },

  "categories": {
    "visual-engineering": {
      // Guide: Gemini 3.1 Pro → Claude Opus
      "model": "github-copilot/gemini-3-pro-preview",
      "fallback_models": [
        "f5ai-anthropic/claude-sonnet-4-6",
        "f5ai-anthropic/claude-sonnet-4-5",
        "f5ai-anthropic/claude-opus-4-6"
      ]
    },
    "ultrabrain": {
      // Guide: GPT-5.4 → Gemini 3.1 Pro → Claude Opus
      "model": "github-copilot/gpt-5.4",
      "fallback_models": [
        "github-copilot/gpt-5.3-codex",
        "github-copilot/gemini-3-pro-preview",
        "f5ai-anthropic/claude-opus-4-6"
      ],
      "reasoningEffort": "high"
    },
    "deep": {
      // Guide: GPT-5.3 Codex → Claude Opus → Gemini 3.1 Pro
      "model": "github-copilot/gpt-5.3-codex",
      "fallback_models": [
        "github-copilot/gpt-5.2-codex",
        "f5ai-anthropic/claude-opus-4-6",
        "github-copilot/gpt-5.2",
        "github-copilot/gemini-3-pro-preview"
      ],
      "reasoningEffort": "high"
    },
    "artistry": {
      // Guide: Gemini 3.1 Pro → Claude Opus → GPT-5.4
      "model": "github-copilot/gemini-3-pro-preview",
      "fallback_models": [
        "f5ai-anthropic/claude-opus-4-6",
        "github-copilot/gpt-5.3-codex"
      ]
    },
    "quick": {
      // Guide: GPT-5.4 Mini → Haiku → Gemini Flash → GPT-5-Nano
      // Using Haiku as primary (GPT-5.4 Mini not available on f5ai)
      "model": "f5ai-anthropic/claude-haiku-4-5",
      "fallback_models": [
        "github-copilot/gemini-3-flash-preview",
        "github-copilot/gpt-5-mini",
        "f5ai-openai/gpt-5-nano"
      ]
    },
    "unspecified-low": {
      // Guide: Claude Sonnet → GPT-5.3 Codex → Gemini Flash
      "model": "f5ai-anthropic/claude-sonnet-4-6",
      "fallback_models": [
        "f5ai-anthropic/claude-sonnet-4-5",
        "github-copilot/gpt-5.3-codex",
        "github-copilot/gemini-3-flash-preview"
      ]
    },
    "unspecified-high": {
      // Guide: Claude Opus → GPT-5.4
      "model": "f5ai-anthropic/claude-opus-4-6",
      "fallback_models": [
        "f5ai-anthropic/claude-opus-4-5",
        "github-copilot/gpt-5.4",
        "github-copilot/gpt-5.3-codex",
        "f5ai-anthropic/claude-sonnet-4-6"
      ]
    },
    "writing": {
      // Guide: Gemini Flash → Claude Sonnet
      "model": "github-copilot/gemini-3-flash-preview",
      "fallback_models": [
        "f5ai-anthropic/claude-sonnet-4-6",
        "f5ai-anthropic/claude-sonnet-4-5",
        "f5ai-anthropic/claude-haiku-4-5"
      ]
    }
  },

  "background_task": {
    // Increased concurrency since no rate limit issues
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "f5ai-anthropic": 5,
      "f5ai-openai": 5,
      "f5ai-grok": 5,
      "github-copilot": 5
      // Add other providers here when switching:
      // "anthropic": 5,
      // "openai": 5,
      // "openrouter": 3
    }
  },

  "tmux": {
    "enabled": false,
    "layout": "main-vertical"
  },

  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": false
  },

  "ralph_loop": {
    "enabled": true,
    "default_max_iterations": 100
  },

  "experimental": {
    "auto_resume": true,
    "aggressive_truncation": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": {
        "enabled": true,
        "turns": 3
      },
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "supersede_writes": {
          "enabled": true,
          "aggressive": false
        },
        "purge_errors": {
          "enabled": true,
          "turns": 5
        }
      }
    }
  },

  // Disabled to reduce prompt noise - agent usage is already well understood
  // Disabled hooks:
  // - agent-usage-reminder: Reduces prompt noise (usage is well understood)
  // - auto-update-checker: Prevents npm registry network calls (sandbox compliance)
  "disabled_hooks": ["agent-usage-reminder", "auto-update-checker"],

  // Disabled MCPs (sandbox compliance):
  // oh-my-opencode ships with 3 built-in remote MCPs that contact external APIs:
  // - websearch: Uses Brave Search API
  // - context7: Documentation search via Upstash
  // - grep_app: GitHub code search
  // These are disabled for sandbox compliance (approved provider only, no internet-calling plugins)
  "disabled_mcps": [
    "websearch",
    "context7",
    "grep_app",
    "git",
    "sequential-thinking",
    "atlassian"
  ]
}
