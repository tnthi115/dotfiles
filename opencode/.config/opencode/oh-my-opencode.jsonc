{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",

  // oh-my-opencode configuration
  // Model matching guide: https://github.com/code-yeongyu/oh-my-opencode/blob/dev/docs/guide/agent-model-matching.md
  //
  // New features in oh-my-opencode 3.x
  "new_task_system_enabled": false,
  "model_fallback": true,
  "hashline_edit": true,

  "agents": {
    "build": {
      "model": "f5ai/claude-opus-4-6",
      "fallback_models": ["f5ai/claude-opus-4-5", "f5ai/claude-sonnet-4-6", "f5ai/claude-sonnet-4-5"]
    },
    "plan": {
      "model": "f5ai/claude-opus-4-6",
      "fallback_models": ["f5ai/claude-opus-4-5", "f5ai/claude-sonnet-4-6", "f5ai/claude-sonnet-4-5"]
    },
    "sisyphus": {
      "model": "f5ai/claude-opus-4-6",
      "fallback_models": ["f5ai/claude-opus-4-5", "f5ai/claude-sonnet-4-6", "github-copilot/gpt-5.4", "f5ai/claude-sonnet-4-5"],
      // Extended thinking for complex orchestration
      "thinking": {
        "type": "enabled",
        "budgetTokens": 8000
      },
      // Deployment query routing (xc-planner for prod/staging questions)
      "prompt_append": "CRITICAL: For deployment questions (what's in prod/staging/crt/dev, deployed images, sre-*-model), delegate to @xc-planner. Local CI configs show :latest tags, not actual deployed versions."
    },
    "sisyphus-junior": {
      "model": "f5ai/claude-sonnet-4-6",
      "fallback_models": ["f5ai/claude-sonnet-4-5", "f5ai/claude-haiku-4-5"]
    },
    "prometheus": {
      "model": "f5ai/claude-opus-4-6",
      "fallback_models": ["f5ai/claude-opus-4-5", "github-copilot/gpt-5.4", "github-copilot/gpt-5.3-codex", "github-copilot/gemini-3-pro-preview", "f5ai/claude-sonnet-4-6"],
      // Extended thinking for thorough planning
      "thinking": {
        "type": "enabled",
        "budgetTokens": 10000
      },
      // Deployment query routing (xc-planner for prod/staging questions)
      "prompt_append": "CRITICAL: For deployment questions (what's in prod/staging/crt/dev, deployed images, sre-*-model), delegate to @xc-planner. Local CI configs show :latest tags, not actual deployed versions."
    },
    "metis": {
      "model": "f5ai/claude-opus-4-6",
      "fallback_models": ["f5ai/claude-opus-4-5", "github-copilot/gpt-5.4", "github-copilot/gpt-5.3-codex", "github-copilot/gemini-3-pro-preview", "f5ai/claude-sonnet-4-6"],
      // Extended thinking for gap analysis
      "thinking": {
        "type": "enabled",
        "budgetTokens": 8000
      }
    },
    "momus": {
      // Plan review benefits from GPT's critical analysis
      // GPT-5.4 is the recommended primary for Momus per model matching guide
      "model": "github-copilot/gpt-5.4",
      "fallback_models": ["github-copilot/gpt-5.3-codex", "f5ai/claude-opus-4-6", "github-copilot/gemini-3-pro-preview", "f5ai/claude-sonnet-4-6"],
      "reasoningEffort": "high"
    },
    "oracle": {
      // GPT-5.4 is the recommended primary for Oracle per model matching guide
      "model": "github-copilot/gpt-5.4",
      "fallback_models": ["github-copilot/gpt-5.3-codex", "github-copilot/gemini-3-pro-preview", "f5ai/claude-opus-4-6", "f5ai/claude-sonnet-4-6"],
      // Extended thinking for architecture decisions
      "thinking": {
        "type": "enabled",
        "budgetTokens": 12000
      }
    },
    "librarian": {
      "model": "github-copilot/gemini-3-flash-preview",
      "fallback_models": ["f5ai/claude-haiku-4-5", "github-copilot/gpt-5-mini", "f5ai/gpt-5-nano"]
    },
    "explore": {
      // Fast, cheap model for codebase grep - doesn't need heavy reasoning
      "model": "github-copilot/grok-code-fast-1",
      "fallback_models": ["f5ai/claude-haiku-4-5", "github-copilot/gpt-5-mini", "f5ai/gpt-5-nano"]
    },
    "multimodal-looker": {
      "model": "github-copilot/gpt-5.4",
      "fallback_models": ["github-copilot/gpt-5.3-codex", "github-copilot/gpt-5", "github-copilot/gpt-5-mini", "github-copilot/gemini-3-pro-preview", "f5ai/claude-sonnet-4-6"]
    },
    "hephaestus": {
      // Autonomous Deep Worker - GPT Codex optimized
      // Goal-oriented execution, deep exploration before action, comprehensive context gathering
      // Inspired by AmpCode's deep mode - autonomous problem-solving with thorough research
      "model": "f5ai/gpt-5.3-codex",
      "fallback_models": ["github-copilot/gpt-5.3-codex", "github-copilot/gpt-5.4", "github-copilot/gpt-5.2-codex", "f5ai/claude-opus-4-6"],
      "reasoningEffort": "xhigh",
      // Deployment query routing (xc-planner for prod/staging questions)
      "prompt_append": "CRITICAL: For deployment questions (what's in prod/staging/crt/dev, deployed images, sre-*-model), delegate to @xc-planner. Local CI configs show :latest tags, not actual deployed versions."
    },
    "atlas": {
      // Session navigation is lightweight
      "model": "f5ai/claude-sonnet-4-6",
      "fallback_models": ["f5ai/claude-sonnet-4-5", "github-copilot/gpt-5.4", "f5ai/claude-haiku-4-5"]
    }
  },

  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-3-pro-preview",
      "fallback_models": ["f5ai/claude-sonnet-4-6", "f5ai/claude-sonnet-4-5", "f5ai/claude-opus-4-6"]
    },
    "ultrabrain": {
      // Maximum reasoning capability — GPT-5.4 per model matching guide
      "model": "github-copilot/gpt-5.4",
      "fallback_models": ["github-copilot/gpt-5.3-codex", "github-copilot/gemini-3-pro-preview", "f5ai/claude-opus-4-6"],
      "reasoningEffort": "high"
    },
    "deep": {
      // Goal-oriented autonomous problem-solving
      // Thorough research before action, for hairy problems requiring deep understanding
      // GPT-5.3 Codex for deep coding — autonomous exploration style
      "model": "github-copilot/gpt-5.3-codex",
      "fallback_models": ["github-copilot/gpt-5.2-codex", "github-copilot/gpt-5.2", "f5ai/claude-opus-4-6"],
      "reasoningEffort": "high"
    },
    "artistry": {
      "model": "github-copilot/gemini-3-pro-preview",
      "fallback_models": ["f5ai/claude-opus-4-6", "github-copilot/gpt-5.3-codex"]
    },
    "quick": {
      // Fast, cheap for trivial tasks
      "model": "f5ai/claude-haiku-4-5",
      "fallback_models": ["github-copilot/gemini-3-flash-preview", "github-copilot/gpt-5-mini", "f5ai/gpt-5-nano"]
    },
    "unspecified-low": {
      "model": "f5ai/claude-sonnet-4-6",
      "fallback_models": ["f5ai/claude-sonnet-4-5", "f5ai/claude-haiku-4-5"]
    },
    "unspecified-high": {
      "model": "f5ai/claude-opus-4-6",
      "fallback_models": ["f5ai/claude-opus-4-5", "github-copilot/gpt-5.4", "github-copilot/gpt-5.3-codex", "f5ai/claude-sonnet-4-6"]
    },
    "writing": {
      "model": "github-copilot/gemini-3-flash-preview",
      "fallback_models": ["f5ai/claude-sonnet-4-6", "f5ai/claude-sonnet-4-5", "f5ai/claude-haiku-4-5"]
    }
  },

  "background_task": {
    // Increased concurrency since no rate limit issues
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "f5ai": 5,
      "github-copilot": 5
      // Add other providers here when switching:
      // "anthropic": 5,
      // "openai": 5,
      // "openrouter": 3
    }
  },

  "tmux": {
    "enabled": false,
    "layout": "main-vertical"
  },

  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": false
  },

  "ralph_loop": {
    "enabled": true,
    "default_max_iterations": 100
  },

  "experimental": {
    "auto_resume": true,
    "aggressive_truncation": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": {
        "enabled": true,
        "turns": 3
      },
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "supersede_writes": {
          "enabled": true,
          "aggressive": false
        },
        "purge_errors": {
          "enabled": true,
          "turns": 5
        }
      }
    }
  },

  // Disabled to reduce prompt noise - agent usage is already well understood
  // Disabled hooks:
  // - agent-usage-reminder: Reduces prompt noise (usage is well understood)
  // - auto-update-checker: Prevents npm registry network calls (sandbox compliance)
  "disabled_hooks": ["agent-usage-reminder", "auto-update-checker"],

  // Disabled MCPs (sandbox compliance):
  // oh-my-opencode ships with 3 built-in remote MCPs that contact external APIs:
  // - websearch: Uses Brave Search API
  // - context7: Documentation search via Upstash
  // - grep_app: GitHub code search
  // These are disabled for sandbox compliance (approved provider only, no internet-calling plugins)
  "disabled_mcps": ["websearch", "context7", "grep_app", "git", "sequential-thinking", "atlassian"]
}
