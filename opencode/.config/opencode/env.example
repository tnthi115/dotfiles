# OpenCode Environment Configuration
# Copy this file to .env and fill in your actual values

# ═══════════════════════════════════════════════════════════════════════════════
# F5AI Provider Configuration (Required for F5AI providers)
# ═══════════════════════════════════════════════════════════════════════════════

# Shared API key for all F5AI endpoints
F5AI_API_KEY=your_f5ai_api_key_here

# Provider-specific API endpoints
F5AI_ANTHROPIC_API_URL=https://your-anthropic-endpoint.example.com/v1
F5AI_OPENAI_API_URL=https://your-openai-endpoint.example.com/v1
F5AI_GROK_API_URL=https://your-grok-endpoint.example.com/v1
F5AI_MOONSHOT_API_URL=https://your-moonshot-endpoint.example.com/v1

# ═══════════════════════════════════════════════════════════════════════════════
# CodeBurro Provider Configuration
# ═══════════════════════════════════════════════════════════════════════════════

CODEBURRO_API_URL=https://your-codeburro-endpoint.example.com/v1
CODEBURRO_API_KEY=your_codeburro_api_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# GitLab MCP Server
# ═══════════════════════════════════════════════════════════════════════════════

GITLAB_TOKEN=your_gitlab_personal_access_token_here

# ═══════════════════════════════════════════════════════════════════════════════
# Atlassian MCP Server (JIRA + Confluence)
# ═══════════════════════════════════════════════════════════════════════════════

F5_JIRA_URL=https://your-jira-instance.example.com
F5_JIRA_PAT=your_jira_personal_access_token_here
F5_CONFLUENCE_URL=https://your-confluence-instance.example.com
F5_CONFLUENCE_PAT=your_confluence_personal_access_token_here

# ═══════════════════════════════════════════════════════════════════════════════
# Optional: Notification Plugin (Telegram)
# ═══════════════════════════════════════════════════════════════════════════════

# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here
# TELEGRAM_BOT_USERNAME=@YourBotUsername
# TELEGRAM_IDLE_TIMEOUT=300000
# TELEGRAM_CHECK_INTERVAL=30000
# TELEGRAM_ENABLED=true
