{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",
  "compress": {
    // Global percentage-based limits — scales with each model's context window.
    //
    // Why percentages vs flat numbers?
    // A flat 50K limit on a 1M model means nudges at 5% usage, wasting 950K.
    // Percentages keep the same relative pressure across 128K-1M models.
    //
    // System prompt: ~30-35K tokens (AGENTS.md + memory + skills + base prompt).
    // 40% of 128K = 51K, giving ~16K working room before soft nudges.
    // 40% of 262K = 105K, giving ~70K working room (Kimi K2.6).
    // 40% of 1M = 400K, giving ~365K working room (Copilot Claude Opus).
    "minContextLimit": "40%",
    "maxContextLimit": "70%",
    // Nudge every 3 tool calls once past maxContextLimit
    "nudgeFrequency": 3,
    // Keep user messages intact — don't summarize away user intent
    "protectUserMessages": true
  },
  // Protect recent tool outputs from premature pruning
  "turnProtection": {
    "enabled": true,
    "turns": 4
  },
  "strategies": {
    // Remove duplicate tool outputs (useful for subagent-heavy workflows)
    "deduplication": { "enabled": true },
    // Purge failed tool calls after 3 turns (failed calls waste context)
    "purgeErrors": {
      "enabled": true,
      "turns": 3
    }
  }
}
