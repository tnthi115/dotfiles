{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",

  // =============================================================================
  // COST-OPTIMIZED OH-MY-OPENAGENT CONFIGURATION
  // =============================================================================
  // Strategy:
  // - Primary orchestrator (Sisyphus): f5ai-moonshot/Kimi-K2.6 (cheap)
  // - All specialist subagents: github-copilot/* models (free)
  // - Fallback chains: Kimi-K2.5 first, then Copilot models
  // - Background tasks: minimized concurrency to avoid accidental token burn
  // - Explicit subagent calls preferred over background task() delegation
  // =============================================================================

  "new_task_system_enabled": true,
  "model_fallback": true,
  "hashline_edit": true,

  // ---------------------------------------------------------------------------
  // AGENTS: Primary model = cheap Kimi. Fallbacks = Copilot (subagent calls
  // don't consume premium requests).
  // ---------------------------------------------------------------------------
  "agents": {
    // Main orchestrator — cheap daily driver for orchestration
    "sisyphus": {
      "model": "f5ai-moonshot/Kimi-K2.6",
      "fallback_models": [
        "f5ai-moonshot/Kimi-K2.5",
        "github-copilot/claude-opus-4.6",
        "github-copilot/claude-sonnet-4.6",
        "github-copilot/gpt-5.4",
        "github-copilot/gpt-5.3-codex"
      ],
      "prompt_append": "CRITICAL: For deployment questions (what's in prod/staging/crt/dev, deployed images, sre-*-model), delegate to @xc-planner. Local CI configs show :latest tags, not actual deployed versions."
    },

    // Lightweight task executor — Copilot only (subagent calls don't consume
    // premium requests)
    "sisyphus-junior": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        "github-copilot/claude-sonnet-4.5",
        "github-copilot/gpt-5.4",
        "github-copilot/claude-haiku-4.5"
      ]
    },

    // Strategic planner — Kimi primary, Copilot fallbacks
    "prometheus": {
      "model": "f5ai-moonshot/Kimi-K2.6",
      "fallback_models": [
        "f5ai-moonshot/Kimi-K2.5",
        "github-copilot/claude-opus-4.6",
        "github-copilot/gpt-5.4",
        "github-copilot/gemini-2.5-pro",
        "github-copilot/claude-sonnet-4.6"
      ],
      "prompt_append": "CRITICAL: For deployment questions (what's in prod/staging/crt/dev, deployed images, sre-*-model), delegate to @xc-planner. Local CI configs show :latest tags, not actual deployed versions."
    },

    // Plan gap analyzer — Copilot only (subagent calls don't consume premium
    // requests)
    "metis": {
      "model": "github-copilot/gpt-5.4",
      "fallback_models": [
        "github-copilot/claude-opus-4.6",
        "f5ai-moonshot/Kimi-K2.5",
        "github-copilot/gpt-5.3-codex",
        "github-copilot/claude-sonnet-4.6"
      ]
    },

    // Ruthless reviewer — Copilot GPT-5.4 xhigh (cost-optimized from 5.5)
    "momus": {
      "model": "github-copilot/gpt-5.4",
      "fallback_models": [
        "github-copilot/claude-opus-4.6",
        "github-copilot/gemini-2.5-pro",
        "github-copilot/claude-opus-4.5",
        "github-copilot/claude-sonnet-4.6"
      ],
      "reasoningEffort": "xhigh"
    },

    // Architecture consultant — Copilot GPT-5.4 high (cost-optimized from 5.5)
    "oracle": {
      "model": "github-copilot/gpt-5.4",
      "fallback_models": [
        "github-copilot/gemini-2.5-pro",
        "github-copilot/claude-opus-4.6",
        "github-copilot/claude-opus-4.5",
        "github-copilot/claude-sonnet-4.6"
      ],
      "reasoningEffort": "high"
    },

    // Fast codebase grep — Copilot cheap models only
    "librarian": {
      "model": "github-copilot/claude-haiku-4.5",
      "fallback_models": [],
      "maxTokens": 8000
    },

    // Fast exploration — Copilot cheap models only
    "explore": {
      "model": "github-copilot/claude-haiku-4.5",
      "fallback_models": ["github-copilot/grok-code-fast-1"],
      "maxTokens": 8000
    },

    // Vision/screenshots — Copilot primary, Kimi fallback
    "multimodal-looker": {
      "model": "github-copilot/gpt-5.4",
      "fallback_models": ["f5ai-moonshot/Kimi-K2.5"]
    },

    // Autonomous deep worker — Copilot GPT-5.4 (cost-optimized)
    "hephaestus": {
      "model": "github-copilot/gpt-5.4",
      "fallback_models": [
        "github-copilot/gpt-5.3-codex",
        "github-copilot/gpt-5.2-codex"
      ],
      "reasoningEffort": "medium",
      "prompt_append": "CRITICAL: For deployment questions (what's in prod/staging/crt/dev, deployed images, sre-*-model), delegate to @xc-planner. Local CI configs show :latest tags, not actual deployed versions."
    },

    // Todo orchestrator — Kimi primary (cheap orchestration), Copilot fallbacks
    "atlas": {
      "model": "f5ai-moonshot/Kimi-K2.6",
      "fallback_models": [
        "f5ai-moonshot/Kimi-K2.5",
        "github-copilot/claude-sonnet-4.6",
        "github-copilot/claude-sonnet-4.5",
        "github-copilot/gpt-5.4",
        "github-copilot/claude-haiku-4.5"
      ]
    }
  },

  // ---------------------------------------------------------------------------
  // CATEGORIES: Domain-specific delegation to Copilot (subagent calls don't
  // consume premium requests)
  // ---------------------------------------------------------------------------
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-2.5-pro",
      "fallback_models": [
        "github-copilot/claude-opus-4.6",
        "github-copilot/claude-opus-4.5",
        "github-copilot/claude-sonnet-4.6",
        "github-copilot/claude-sonnet-4.5",
        "f5ai-moonshot/Kimi-K2.5"
      ]
    },
    "ultrabrain": {
      "model": "github-copilot/gpt-5.4",
      "fallback_models": [
        "github-copilot/gemini-2.5-pro",
        "github-copilot/claude-opus-4.6",
        "github-copilot/gpt-5.3-codex"
      ],
      "reasoningEffort": "high"
    },
    "deep": {
      "model": "github-copilot/gpt-5.3-codex",
      "fallback_models": [
        "github-copilot/claude-opus-4.6",
        "github-copilot/gemini-2.5-pro",
        "github-copilot/gpt-5.2-codex"
      ],
      "reasoningEffort": "high"
    },
    "artistry": {
      "model": "github-copilot/gemini-2.5-pro",
      "fallback_models": [
        "github-copilot/claude-opus-4.6",
        "github-copilot/gpt-5.4"
      ]
    },
    "quick": {
      "model": "github-copilot/claude-haiku-4.5",
      "fallback_models": ["github-copilot/gemini-3-flash-preview"]
    },
    "unspecified-low": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        "github-copilot/claude-sonnet-4.5",
        "github-copilot/gpt-5.3-codex",
        "f5ai-moonshot/Kimi-K2.5",
        "github-copilot/gemini-3-flash-preview"
      ]
    },
    "unspecified-high": {
      "model": "github-copilot/gpt-5.4",
      "fallback_models": [
        "github-copilot/claude-opus-4.5",
        "github-copilot/gpt-5.4",
        "f5ai-moonshot/Kimi-K2.5",
        "github-copilot/claude-sonnet-4.6",
        "github-copilot/gpt-5.3-codex"
      ]
    },
    "writing": {
      "model": "github-copilot/gemini-3-flash-preview",
      "fallback_models": [
        "f5ai-moonshot/Kimi-K2.5",
        "github-copilot/claude-sonnet-4.6",
        "github-copilot/claude-sonnet-4.5",
        "github-copilot/claude-haiku-4.5"
      ]
    }
  },

  // ---------------------------------------------------------------------------
  // BACKGROUND TASKS: Minimized to avoid accidental token burn
  // ---------------------------------------------------------------------------
  // We prefer explicit subagent calls over background task() delegation.
  // Concurrency limits prevent runaway parallel expensive calls.
  // ---------------------------------------------------------------------------
  "background_task": {
    "defaultConcurrency": 3,
    "staleTimeoutMs": 180000,
    "providerConcurrency": {
      "f5ai-moonshot": 3,
      "github-copilot": 5
    },
    "modelConcurrency": {
      "github-copilot/claude-opus-4.6": 1,
      "github-copilot/gpt-5.4": 2
    }
  },

  // ---------------------------------------------------------------------------
  // SISYPHUS AGENT: Enable orchestration, disable default builder (use native)
  // ---------------------------------------------------------------------------
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },

  // ---------------------------------------------------------------------------
  // TMUX: Disabled (we use native subagents instead of tmux panes)
  // ---------------------------------------------------------------------------
  // "tmux": {
  //   "enabled": false,
  //   "layout": "main-vertical",
  //   "main_pane_size": 60,
  //   "main_pane_min_width": 80,
  //   "agent_pane_min_width": 40,
  //   "isolation": false
  // },

  // ---------------------------------------------------------------------------
  // GIT MASTER: Preserve existing footer settings
  // ---------------------------------------------------------------------------
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": false,
    "git_env_prefix": "GIT_",
    "default_strategy": "rebase"
  },

  // ---------------------------------------------------------------------------
  // RALPH LOOP: Enabled for self-referential task completion
  // ---------------------------------------------------------------------------
  "ralph_loop": {
    "enabled": true,
    "default_max_iterations": 100,
    "default_strategy": "task_complete"
  },

  // ---------------------------------------------------------------------------
  // RUNTIME FALLBACK: Fast failover to Copilot on Kimi errors
  // ---------------------------------------------------------------------------
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },

  // ---------------------------------------------------------------------------
  // EXPERIMENTAL: Enable task system, aggressive truncation, auto-resume
  // ---------------------------------------------------------------------------
  "experimental": {
    "auto_resume": true,
    "aggressive_truncation": true,
    "task_system": true,
    "protected_tools": [
      "lsp_diagnostics",
      "lsp_rename",
      "lsp_find_references",
      "lsp_goto_definition"
    ],
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": {
        "enabled": true,
        "turns": 3
      },
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "supersede_writes": {
          "enabled": true,
          "aggressive": false
        },
        "purge_errors": {
          "enabled": true,
          "turns": 5
        }
      }
    }
  },

  // ---------------------------------------------------------------------------
  // DISABLED HOOKS: Remove token-heavy hooks to reduce per-request overhead
  // ---------------------------------------------------------------------------
  // Keep:
  // - todo-continuation-enforcer (critical for task completion)
  // - session-recovery (resilience)
  // - session-notification (visibility)
  // - ralph-loop (core feature)
  // - start-work (Prometheus entry point)
  // - runtime-fallback (resilience)
  //
  // Remove:
  // - agent-usage-reminder (reduces prompt noise)
  // - auto-update-checker (prevents npm registry calls)
  // - startup-toast (sub-feature of auto-update-checker)
  // - compaction-context-injector (we have opencode-dcp)
  // - directory-agents-injector (native AGENTS.md support in OpenCode 1.1.37+)
  // - comment-checker (optional, can re-enable if needed)
  // ---------------------------------------------------------------------------
  "disabled_hooks": [
    "agent-usage-reminder",
    "auto-update-checker",
    "startup-toast",
    "compaction-context-injector",
    "directory-agents-injector",
    "comment-checker"
  ],

  // ---------------------------------------------------------------------------
  // DISABLED MCPS: Sandbox compliance (same as current config)
  // ---------------------------------------------------------------------------
  "disabled_mcps": ["websearch", "context7", "grep_app"]

  // ---------------------------------------------------------------------------
  // DISABLED COMMANDS: None (keep all commands available)
  // ---------------------------------------------------------------------------
  // "disabled_commands": []
}
