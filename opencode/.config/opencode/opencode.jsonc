{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-opencode", "opencode-notify", "opencode-agent-memory"],
  "share": "disabled",
  "autoupdate": "notify",
  "instructions": [
    "*/AGENTS.md",
    "AGENTS.md",
    "README.md",
    // NOTE: Removed docs/**/*.md - too risky globally (can overflow context)
    // Add per-project in .opencode/opencode.jsonc if needed
    "pbdoc/docs.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true
  },
  "agent": {
    // "compaction": {
    //   "model": "f5ai/claude-sonnet-4-5",
    // },
    "xc-planner": {
      "mode": "subagent"
    }
  },
  "small_model": "f5ai/claude-haiku-4-5",
  "permission": {
    "bash": {
      // Prevent accidental pushes — agents should not push directly
      "git push *": "deny",
      // Safety guard against destructive filesystem operations
      "rm -rf *": "deny"
    },
    // You should review what the agent is fetching from the internet
    "webfetch": "ask",
    "websearch": "ask"
  },
  "enabled_providers": ["f5ai", "github-copilot"],
  "disabled_providers": ["opencode"],
  "provider": {
    "f5ai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "F5AI",
      "options": {
        "baseURL": "{env:F5AI_API_URL}",
        "apiKey": "{env:F5AI_API_KEY}"
      },
      "models": {
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5"
        },
        "claude-opus-4-5": {
          "name": "Claude Opus 4.5"
        },
        "claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5"
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6"
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6"
        },
        "gpt-5.2-codex-max": {
          "name": "GPT-5.2-Codex-Max"
        },
        "gpt-5.1-codex-max": {
          "name": "GPT-5.1-Codex-Max"
        },
        "gpt-5.2-codex": {
          "name": "GPT-5.2-Codex"
        },
        "gpt-5.2": {
          "name": "GPT-5.2"
        },
        "gpt-5": {
          "name": "GPT-5"
        },
        "gpt-5-mini": {
          "name": "GPT-5-mini"
        },
        "gpt-5-codex": {
          "name": "GPT-5-Codex"
        },
        "gpt-5-nano": {
          "name": "GPT-5-Nano"
        },
        "gpt-4.1": {
          "name": "GPT-4.1"
        },
        "gpt-4.1-mini": {
          "name": "GPT-4.1-mini"
        },
        "gpt-4o": {
          "name": "GPT-4o"
        },
        "gpt-4o-mini": {
          "name": "GPT-4o-mini"
        },
        "o4-mini": {
          "name": "o4-mini"
        },
        "o3": {
          "name": "o3"
        },
        "o3-mini": {
          "name": "o3-mini"
        },
        "o1": {
          "name": "o1"
        }
      }
    }
  },
  // List of github copilot models available:
  // claude-3.5-sonnet
  // claude-3.7-sonnet
  // claude-sonnet-4.5
  // o3-mini
  // o4-mini
  // gpt-5
  // gpt-5-mini
  // NOTE: Agent model configs now managed by oh-my-opencode.json
  // ==============================================================================
  // MCP SERVER CONFIGURATION STRATEGY
  // ==============================================================================
  //
  // MCP servers are handled differently than oh-my-opencode's built-in MCPs.
  // This config defines which MCP servers are available to OpenCode agents.
  //
  // STRATEGY FOR DUAL-MODE OPERATION (LOCAL vs SANDBOX):
  //
  // 1. LOCAL MODE (Full Features):
  //    - All MCP servers active (git, context7, sequential-thinking, atlassian)
  //    - Provider restrictions not enforced in opencode.jsonc
  //    - Agents have full access to all capabilities
  //
  // 2. SANDBOX MODE (F5AI Only):
  //    - oh-my-opencode.jsonc enforces provider/MCP restrictions at plugin level
  //    - `disabled_mcps` array in oh-my-opencode.jsonc blocks remote APIs
  //    - `disabled_hooks` array disables non-essential background tasks
  //    - Runtime environment enforces these restrictions, not config files
  //
  // WHY NOT ADD 'enabled_providers' HERE?
  //    - Would break 16 'github-copilot/*' model references in oh-my-opencode.jsonc
  //    - Local development mode requires access to GitHub Copilot models
  //    - Provider restrictions are enforced at runtime for sandbox environments
  //    - This config is shared across modes; policy enforcement is in oh-my-opencode
  //
  // MCP SERVER CATEGORIES:
  //
  // [KEPT ACTIVE] Local-Only Servers (No Network):
  //   - git: Repository analysis, history inspection, diff generation
  //   - sequential-thinking: Local chain-of-thought reasoning (no external calls)
  //   - atlassian: Internal APIs (trusted internal network only)
  //
  // [KEPT ACTIVE, DISABLED BY oh-my-opencode] Remote APIs:
  //   - context7: Documentation search (external library lookup)
  //     -> Blocked by oh-my-opencode's `disabled_mcps` for sandbox compliance
  //
  // [NOT CONFIGURED] Other Remote APIs:
  //   - websearch: (Blocked by oh-my-opencode in sandbox mode)
  //   - grep_app: (Blocked by oh-my-opencode in sandbox mode)
  //
  // IMPLEMENTATION NOTES:
  // - Keep this config identical across local and sandbox environments
  // - Mode-specific restrictions are enforced by oh-my-opencode.jsonc
  // - If an MCP server needs to be disabled globally, use oh-my-opencode
  // - Local development uses all MCPs; sandbox uses restricted subset
  //
  // ==============================================================================

