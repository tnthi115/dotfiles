{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent",
    "opencode-notify",
    "opencode-agent-memory",
    "@tarquinen/opencode-dcp@latest",
    // "opencode-smart-title",
    "opencode-vibeguard",
    "@plannotator/opencode@latest"
  ],
  "share": "disabled",
  "autoupdate": "notify",
  "instructions": [
    // NOTE: .opencode/memory/*.md loaded by opencode-agent-memory plugin
    "*/AGENTS.md",
    "AGENTS.md",
    "README.md",
    // NOTE: Removed docs/**/*.md - too risky globally (can overflow context)
    // Add per-project in .opencode/opencode.jsonc if needed
    "pbdoc/docs.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "agent": {
    // Disabled: oh-my-openagent provides Sisyphus and Prometheus.
    // "build": { ... },
    // "plan": { ... },
    "xc-planner": {
      "mode": "subagent"
    }
  },
  // small_model: lightweight agent for trivial tasks (summaries, formatting, simple classification)
  // "small_model": "f5ai-anthropic/claude-haiku-4-5",
  // "small_model": "f5ai-openai/gpt-5-nano",
  // NOTE: github-copilot/gpt-5.4-mini does not exist in Copilot model list.
  // Correct Copilot small models: gpt-5-mini, claude-haiku-4.5
  "small_model": "github-copilot/gpt-5-mini",
  "permission": {
    "bash": {
      // Prevent accidental pushes — agents should not push directly
      "git push *": "deny",
      // Safety guard against destructive filesystem operations
      "rm -rf *": "deny"
    },
    // You should review what the agent is fetching from the internet
    "webfetch": "ask",
    "websearch": "ask"
  },
  "enabled_providers": [
    "f5ai-anthropic",
    "f5ai-openai",
    "f5ai-grok",
    "f5ai-moonshot",
    "github-copilot",
    "codeburro-qwen"
  ],
  "disabled_providers": ["opencode"],
  "provider": {
    // Native Anthropic API — enables proper thinking support and 1M token context
    // The OpenAI-compat layer was suppressing thinking for Claude models
    "f5ai-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "F5AI (Anthropic)",
      "options": {
        "baseURL": "{env:F5AI_ANTHROPIC_API_URL}",
        "apiKey": "{env:F5AI_API_KEY}",
        "headers": {
          "anthropic-beta": "interleaved-thinking-2025-05-14"
        }
      },
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6",
          "reasoning": true,
          "limit": { "context": 1000000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "options": { "thinking": { "type": "adaptive" } },
          "variants": { "off": { "thinking": { "type": "disabled" } } }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "reasoning": true,
          "limit": { "context": 1000000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "options": { "thinking": { "type": "adaptive" } },
          "variants": { "off": { "thinking": { "type": "disabled" } } }
        },
        "claude-opus-4-5": {
          "name": "Claude Opus 4.5",
          "reasoning": true,
          "limit": { "context": 200000, "output": 64000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "options": {
            "thinking": { "type": "enabled", "budgetTokens": 8192 }
          },
          "variants": { "off": { "thinking": { "type": "disabled" } } }
        },
        "claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        }
      }
    },
    // OpenAI API — GPT models
    "f5ai-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "F5AI (OpenAI)",
      "options": {
        "baseURL": "{env:F5AI_OPENAI_API_URL}",
        "apiKey": "{env:F5AI_API_KEY}"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT 5.5",
          "reasoning": true,
          "limit": { "context": 1050000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "gpt-5.4": {
          "name": "GPT 5.4",
          "reasoning": true,
          "release_date": "2026-03-01",
          "limit": { "context": 1050000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "gpt-5.3-codex": {
          "name": "GPT 5.3 Codex",
          "reasoning": true,
          "release_date": "2026-02-01",
          "limit": { "context": 272000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "gpt-5.2-codex": {
          "name": "GPT 5.2 Codex",
          "reasoning": true,
          "limit": { "context": 272000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "gpt-5.2": {
          "name": "GPT 5.2",
          "reasoning": true,
          "release_date": "2026-01-01",
          "limit": { "context": 272000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "gpt-5.1-codex-max": {
          "name": "GPT 5.1 Codex Max",
          "reasoning": true,
          "limit": { "context": 272000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "gpt-5.1": {
          "name": "GPT 5.1",
          "reasoning": true,
          "limit": { "context": 272000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "gpt-5": {
          "name": "GPT 5",
          "reasoning": true,
          "limit": { "context": 272000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "gpt-5-mini": {
          "name": "GPT 5 Mini",
          "reasoning": true,
          "release_date": "2026-01-01",
          "limit": { "context": 272000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "gpt-5-codex": {
          "name": "GPT 5 Codex",
          "reasoning": true,
          "limit": { "context": 272000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "gpt-5-nano": {
          "name": "GPT 5 Nano",
          "reasoning": true,
          "release_date": "2026-01-01",
          "limit": { "context": 272000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "gpt-4.1": {
          "name": "GPT 4.1",
          "limit": { "context": 1047576, "output": 32768 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "gpt-4.1-mini": {
          "name": "GPT 4.1 Mini",
          "limit": { "context": 1047576, "output": 32768 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "gpt-4o": {
          "name": "GPT 4o",
          "limit": { "context": 128000, "output": 16384 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "gpt-4o-transcribe": {
          "name": "GPT 4o Transcribe",
          "limit": { "context": 16000, "output": 2000 },
          "modalities": { "input": ["text", "audio"], "output": ["text"] }
        },
        "gpt-image-1": {
          "name": "GPT Image 1",
          "limit": { "context": 0, "output": 0 },
          "modalities": { "input": ["text"], "output": ["image"] }
        },
        "o4-mini": {
          "name": "o4 Mini",
          "reasoning": true,
          "limit": { "context": 200000, "output": 100000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "o3": {
          "name": "o3",
          "reasoning": true,
          "limit": { "context": 200000, "output": 100000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "o3-mini": {
          "name": "o3 Mini",
          "reasoning": true,
          "limit": { "context": 200000, "output": 100000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "o1": {
          "name": "o1",
          "reasoning": true,
          "limit": { "context": 200000, "output": 100000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        }
      }
    },
    // Grok API — via OpenAI-compatible endpoint
    "f5ai-grok": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "F5AI (Grok)",
      "options": {
        "baseURL": "{env:F5AI_GROK_API_URL}",
        "apiKey": "{env:F5AI_API_KEY}"
      },
      "models": {
        "grok-4": {
          "name": "Grok 4",
          "limit": { "context": 131072, "output": 131072 },
          "modalities": { "input": ["text"], "output": ["text"] }
        },
        "grok-code-fast-1": {
          "name": "Grok Code Fast 1",
          "limit": { "context": 131072, "output": 131072 },
          "modalities": { "input": ["text"], "output": ["text"] }
        }
      }
    },
    // Moonshot/Kimi API — via OpenAI-compatible endpoint
    "f5ai-moonshot": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "F5AI (Moonshot)",
      "options": {
        "baseURL": "{env:F5AI_MOONSHOT_API_URL}",
        "apiKey": "{env:F5AI_API_KEY}"
      },
      "models": {
        "Kimi-K2.5": {
          "name": "Kimi K2.5",
          "limit": { "context": 262144, "output": 262144 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "Kimi-K2.6": {
          "name": "Kimi K2.6",
          "limit": { "context": 262144, "output": 262144 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        }
      }
    },
    // CodeBurro Qwen API — via OpenAI-compatible endpoint
    "codeburro-qwen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CodeBurro (Qwen)",
      "options": {
        "baseURL": "{env:CODEBURRO_API_URL}",
        "apiKey": "{env:CODEBURRO_API_KEY}"
      },
      "models": {
        "qwen-3.6": {
          "name": "Qwen 3.6",
          "limit": { "context": 131072, "output": 131072 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        }
      }
    }
  },
  // List of F5AI models available (as of 2026-04-27):
  // Anthropic: claude-opus-4-6, claude-sonnet-4-6, claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5
  // OpenAI: gpt-5.5, gpt-5.4, gpt-5.3-codex, gpt-5.2-codex, gpt-5.2, gpt-5.1-codex-max, gpt-5.1
  //          gpt-5, gpt-5-mini, gpt-5-codex, gpt-5-nano, gpt-4.1, gpt-4.1-mini, gpt-4o, gpt-4o-transcribe
  //          gpt-image-1, o4-mini, o3, o3-mini, o1
  // Grok: grok-4, grok-code-fast-1
  // Moonshot: Kimi-K2.5, Kimi-K2.6
  // CodeBurro: qwen-3.6
  //
  // GitHub Copilot models (run `opencode models github-copilot` to refresh):
  // claude-haiku-4.5, claude-opus-4.5, claude-opus-4.6, claude-opus-41
  // claude-sonnet-4, claude-sonnet-4.5, claude-sonnet-4.6
  // gemini-2.5-pro, gemini-3-flash-preview, gemini-3-pro-preview, gemini-3.1-pro-preview
  // gpt-4.1, gpt-4o, gpt-5, gpt-5-mini, gpt-5.1, gpt-5.1-codex, gpt-5.1-codex-max, gpt-5.1-codex-mini
  // gpt-5.2, gpt-5.2-codex, gpt-5.3-codex, gpt-5.4
  // grok-code-fast-1
  //
  // Required environment variables for split providers:
  //   F5AI_API_KEY           — Shared API key for all F5AI endpoints
  //   F5AI_ANTHROPIC_API_URL — Anthropic native API endpoint
  //   F5AI_OPENAI_API_URL   — OpenAI API endpoint
  //   F5AI_GROK_API_URL     — Grok API endpoint (OpenAI-compatible)
  //   F5AI_MOONSHOT_API_URL — Moonshot/Kimi API endpoint (OpenAI-compatible)
  //   CODEBURRO_API_URL     — CodeBurro Qwen API endpoint (OpenAI-compatible)
  //   CODEBURRO_API_KEY     — CodeBurro Qwen API key
  //
  // NOTE: Agent model configs now managed by oh-my-openagent.jsonc
  // ==============================================================================
  // MCP SERVER CONFIGURATION STRATEGY
  // ==============================================================================
  //
  // MCP servers are handled via OpenCode's native MCP configuration.
  // This config defines which MCP servers are available to OpenCode agents.
  //
  // STRATEGY FOR DUAL-MODE OPERATION (LOCAL vs SANDBOX):
  //
  // 1. LOCAL MODE (Full Features):
  //    - All MCP servers active (git, context7, sequential-thinking, atlassian)
  //    - Provider restrictions not enforced in opencode.jsonc
  //    - Agents have full access to all capabilities
  //
  // 2. SANDBOX MODE (F5AI Only):
  //    - oh-my-openagent.jsonc enforces provider/MCP restrictions at plugin level
  //    - `disabled_mcps` array in oh-my-openagent.jsonc blocks remote APIs
  //    - `disabled_hooks` array disables non-essential background tasks
  //    - Runtime environment enforces these restrictions, not config files
  //
  // WHY NOT ADD 'enabled_providers' HERE?
  //    - Would break 16 'github-copilot/*' model references in oh-my-openagent.jsonc
  //    - Local development mode requires access to GitHub Copilot models
  //    - Provider restrictions are enforced at runtime for sandbox environments
  //    - This config is shared across modes; policy enforcement is in oh-my-openagent
  //
  // MCP SERVER CATEGORIES:
  //
  // [KEPT ACTIVE] Local-Only Servers (No Network):
  //   - git: Repository analysis, history inspection, diff generation
  //   - sequential-thinking: Local chain-of-thought reasoning (no external calls)
  //   - atlassian: Internal APIs (trusted internal network only)
  //
  // [KEPT ACTIVE, DISABLED BY oh-my-openagent] Remote APIs:
  //   - context7: Documentation search (external library lookup)
  //     -> Blocked by oh-my-openagent's `disabled_mcps` for sandbox compliance
  //
  // [NOT CONFIGURED] Other Remote APIs:
  //   - websearch: (Blocked by oh-my-openagent in sandbox mode)
  //   - grep_app: (Blocked by oh-my-openagent in sandbox mode)
  //
  // IMPLEMENTATION NOTES:
  // - Keep this config identical across local and sandbox environments
  // - Mode-specific restrictions are enforced by oh-my-openagent.jsonc
  // - If an MCP server needs to be disabled globally, use oh-my-openagent
  // - Local development uses all MCPs; sandbox uses restricted subset
  //
  // ==============================================================================

  "mcp": {
    // "git": {
    //   "type": "local",
    //   "command": ["uvx", "mcp-server-git", "--repository", "${PWD}"]
    // },
    "gitlab": {
      "type": "local",
      "command": ["npx", "-y", "@zereight/mcp-gitlab"],
      "environment": {
        "GITLAB_PERSONAL_ACCESS_TOKEN": "{env:GITLAB_TOKEN}",
        "GITLAB_API_URL": "https://gitlab.com/api/v4/",
        "GITLAB_READ_ONLY_MODE": "false",
        "USE_GITLAB_WIKI": "false",
        "USE_MILESTONE": "false",
        "USE_PIPELINE": "true"
      }
    },
    // prompt: use context7
    // "context7": {
    //   "type": "local",
    //   "command": ["npx", "-y", "@upstash/context7-mcp"],
    //   "environment": {
    //     "DEFAULT_MINIMUM_TOKENS": "5000"
    //   }
    // },
    // prompt: /serena custom command or "activate serena project"
    // NOTE: Commented out - agents don't use Serena automatically.
    // Native LSP tools are better for most operations. Re-enable if needed
    // for symbol-level editing (serena_replace_symbol_body, serena_insert_after_symbol).
    // "serena": {
    //   "type": "local",
    //   "command": [
    //     "uvx",
    //     "--from",
    //     "git+https://github.com/oraios/serena",
    //     "serena",
    //     "start-mcp-server",
    //   ],
    // },
    // prompt: use sequential-thinking, chain-of-thought reasoning, break this down step by step
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    // Atlassian (JIRA + Confluence) - Internal
    // Requires: JIRA_URL, JIRA_PAT, CONFLUENCE_URL, CONFLUENCE_PAT env vars
    // Docs: https://github.com/sooperset/mcp-atlassian
    "atlassian": {
      "type": "local",
      "command": ["uvx", "mcp-atlassian"],
      "environment": {
        "JIRA_URL": "{env:F5_JIRA_URL}",
        "JIRA_PERSONAL_TOKEN": "{env:F5_JIRA_PAT}",
        "JIRA_SSL_VERIFY": "false",
        "CONFLUENCE_URL": "{env:F5_CONFLUENCE_URL}",
        "CONFLUENCE_PERSONAL_TOKEN": "{env:F5_CONFLUENCE_PAT}",
        "CONFLUENCE_SSL_VERIFY": "false"
      }
    }
    // E2B: Secure code execution sandbox
    // "e2b": {
    //   "type": "local",
    //   "command": ["npx", "-y", "@e2b/mcp-server"],
    // },
    // Exa: AI-native search engine
    // "exa": {
    //   "type": "local",
    //   "command": [
    //     "npx",
    //     "-y",
    //     "@exa-labs/exa-mcp-server"
    //   ]
    // },
  },
  "formatter": {
    "rumdl": {
      "command": ["rumdl", "fmt", "--fix", "$FILE"],
      "extensions": [".md", ".markdown"]
    },
    "ruff": {
      "command": ["ruff", "format", "$FILE"],
      "extensions": [".py", ".pyi"]
    },
    "stylua": {
      "command": ["stylua", "$FILE"],
      "extensions": [".lua"]
    },
    "shfmt": {
      "command": ["shfmt", "-i", "2", "-ci", "$FILE"],
      "extensions": [".sh", ".bash", ".zsh"]
    },
    "taplo": {
      "command": ["taplo", "format", "$FILE"],
      "extensions": [".toml"]
    },
    "goimports": {
      "command": ["goimports", "-w", "$FILE"],
      "extensions": [".go"]
    }
  },
  "lsp": {
    "rumdl": {
      "command": ["rumdl", "server", "--stdio"],
      "extensions": [".md", ".markdown"]
    },
    "rust-analyzer": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"]
    },
    "basedpyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"]
    },
    "yaml-language-server": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    },
    "docker-langserver": {
      "command": ["docker-langserver", "--stdio"],
      "extensions": [".dockerfile", "Dockerfile*"]
    },
    "docker-compose-langserver": {
      "command": ["docker-compose-langserver", "--stdio"],
      "extensions": [
        "docker-compose.yml",
        "docker-compose.yaml",
        "compose.yml",
        "compose.yaml"
      ]
    },
    "jsonnet-language-server": {
      "command": ["jsonnet-language-server"],
      "extensions": [".jsonnet", ".libsonnet"]
    },
    "fish-lsp": {
      "command": ["fish-lsp", "start"],
      "extensions": [".fish"]
    },
    "golangci-lint-langserver": {
      "command": ["golangci-lint-langserver"],
      "extensions": [".go"]
    },
    "taplo": {
      "command": ["taplo", "lsp", "stdio"],
      "extensions": [".toml"]
    },
    "typescript-language-server": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx"]
    }
  }
}
