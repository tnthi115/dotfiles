  //   //    "USE_GITLAB_WIKI": "false",
  //   //    "USE_MILESTONE": "false",
  //   //    "USE_PIPELINE": "true",
  //   //  },
  //   //},
  //   // prompt: use context7
  //   "context7": {
  //     "type": "local",
  //     "command": ["npx", "-y", "@upstash/context7-mcp"],
  //     "environment": {
  //       "DEFAULT_MINIMUM_TOKENS": "5000"
  //     }
  //   },
  //   // prompt: /serena custom command or "activate serena project"
  //   // NOTE: Commented out - agents don't use Serena automatically.
  //   // Native LSP tools are better for most operations. Re-enable if needed
  //   // for symbol-level editing (serena_replace_symbol_body, serena_insert_after_symbol).
  //   // "serena": {
  //   //   "type": "local",
  //   //   "command": [
